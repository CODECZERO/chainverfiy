# ─── Pramanik Server Environment Variables ───
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Auth
ATS=your_access_token_secret_here
RTS=your_refresh_token_secret_here
ATE=15m
RTE=7d

# PostgreSQL (Prisma) — Supabase uses Postgres
# IMPORTANT: Prisma cannot use Supabase project HTTPS URLs.
# Use the Postgres URI from Supabase:
# Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=public&sslmode=require

# Optional, used by Prisma migrate as "direct" (avoid pooler)
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=public&sslmode=require

# Redis (optional) — Upstash TLS URL example:
# REDIS_URL=redis://default:<password>@<host>.upstash.io:6379
REDIS_URL=

# Stellar
BLOCKCHAIN_NETWORK=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STACK_ADMIN_SECRET=your_stellar_admin_secret_here
USDC_ASSET_CODE=USDC
USDC_ASSET_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
ESCROW_CONTRACT_ID=your_escrow_contract_id_here

# Twilio WhatsApp (MAJOR CORE FEATURE)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# NVIDIA NIM
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_MODEL=meta/llama-3.1-8b-instruct

# Razorpay UPI
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# IPFS Pinata
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY=gateway.pinata.cloud

# App
APP_URL=http://localhost:3000
