generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions", "driverAdapters", "fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}



enum UserRole {
  SUPPLIER
  BUYER
  VERIFIER
  ADMIN
}

enum ProductStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  FLAGGED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  DISPUTED
  REFUNDED
  COMPLETED
  RETURN_REQUESTED
  RETURNED
}

enum PaymentMethod {
  STELLAR_XLM
  STELLAR_USDC
  STELLAR_OTHER
  UPI
  INTERNAL
}


enum BountyStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
}

enum VoteType {
  REAL
  FAKE
  NEEDS_MORE_PROOF
}

enum BadgeTier {
  VERIFIED_SELLER
  TRUSTED_SELLER
  ELITE_SELLER
}

enum WhatsAppState {
  IDLE
  AWAITING_PRODUCT_NAME
  AWAITING_PRICE
  AWAITING_CATEGORY
  AWAITING_DESCRIPTION
  AWAITING_PROOF_MEDIA
  AWAITING_GPS
  AWAITING_RESUBMIT_PROOF
}

enum NotificationType {
  PRODUCT_VERIFIED
  PRODUCT_FLAGGED
  ORDER_RECEIVED
  PAYMENT_RELEASED
  PAYMENT_REFUNDED
  VOTE_REWARD
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  RETURN_REQUESTED
  RETURN_CONFIRMED
  DELIVERY_CONFIRMED
  PROOF_DEADLINE_PASSED
  REFUND_WINDOW_CLOSING
}

model User {
  id             String   @id @default(uuid())
  email          String?  @unique
  passwordHash   String?
  role           UserRole @default(BUYER)
  stellarWallet  String?  @unique
  managedSecret  String? // For backend-managed wallets
  whatsappNumber String?  @unique
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplierProfile Supplier?
  buyerProfile    BuyerProfile?
  buyerOrders     Order[]            @relation("BuyerOrders")
  votes           Vote[]
  notifications   Notification[]
  trustTokens     TrustTokenLedger[]
  issuedBounties  Bounty[]           @relation("IssuerBounties")
  solvedBounties  Bounty[]           @relation("SolverBounties")
  discussions     Discussion[]
  comments        Comment[]

  @@map("users")
}

model Supplier {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  name           String
  description    String?
  location       String?
  category       String?
  stellarWallet  String?
  managedSecret  String? // For backend-managed wallets
  whatsappNumber String   @unique
  trustScore     Float    @default(0)
  totalSales     Int      @default(0)
  flagCount      Int      @default(0)
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]
  badges   SellerBadge[]
  machineScanners MachineScanner[]

  @@index([trustScore])
  @@index([location])
  @@map("suppliers")
}

model Product {
  id             String        @id @default(uuid())
  supplierId     String
  supplier       Supplier      @relation(fields: [supplierId], references: [id])
  title          String
  description    String?
  category       String
  priceInr       Decimal       @db.Decimal(10, 2)
  priceUsdc      Decimal?      @db.Decimal(18, 7)
  quantity       String?
  status         ProductStatus @default(PENDING_VERIFICATION)
  proofMediaUrls String[]
  qrCodeUrl      String?
  stellarTxId    String?
  voteReal       Int           @default(0)
  voteFake       Int           @default(0)
  voteNeedsProof Int           @default(0)
  verifiedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  stageUpdates StageUpdate[]
  votes        Vote[]
  orders       Order[]
  qrCodes      QRCode[]
  bounties     Bounty[]

  @@index([category])
  @@index([status])
  @@index([priceInr])
  @@index([supplierId])
  @@map("products")
}

model StageUpdate {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  stageName   String
  stageNumber Int
  note        String?
  photoUrl    String?
  videoUrl    String?
  gpsLat      Float?
  gpsLng      Float?
  gpsAddress  String?
  stellarTxId String?
  createdAt   DateTime @default(now())

  @@index([productId])
  @@map("stage_updates")
}

model Vote {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  voteType   VoteType
  reason        String?
  isAccurate    Boolean?
  stakedAmount  Int      @default(0)
  stakeReleased Boolean  @default(false)
  stakeSlashed  Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@map("votes")
}

model Order {
  id                String        @id @default(uuid())
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  buyerId           String
  buyer             User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  quantity          Int           @default(1)
  priceInr          Decimal       @db.Decimal(10, 2)
  priceUsdc         Decimal       @db.Decimal(18, 7)
  paymentMethod     PaymentMethod
  sourceCurrency    String?
  sourceAmount      Decimal?      @db.Decimal(18, 7)
  status            OrderStatus   @default(PENDING)
  escrowContractId  String?
  escrowTxId        String?
  pathPaymentTxId   String?
  releaseTxId       String?
  refundTxId          String?
  buyerRating         Int?
  buyerReview         String?
  qrCodeUrl           String?

  qrBuyerToken        String?       @unique
  qrSupplierToken     String?       @unique
  qrBuyerScannedAt    DateTime?
  qrSupplierScannedAt DateTime?
  deliveryCertCid     String?
  deliveryCertTxId    String?
  deliveredAt         DateTime?

  // ── Shipping Details snapshot ──────────────────────────────────────
  shippingFullName    String?
  shippingPhone        String?
  shippingAddress     String?
  shippingCity        String?
  shippingState       String?
  shippingPincode      String?
  shippingCountry     String?      @default("India")

  // ── Delivery confirmation ──────────────────────────────────────────
  deliveryConfirmedAt  DateTime?   // when buyer clicked "I received it"
  proofDeadlineAt      DateTime?   // deliveryConfirmedAt + 72 hours
  autoCompletedAt      DateTime?   // set by background job if no proof in 72h

  // ── Buyer dispute proof ────────────────────────────────────────────
  buyerProofCid        String?     // IPFS CID of buyer's evidence (photo/video)
  buyerProofUploadedAt DateTime?
  buyerDisputeReason   String?     // free text, max 500 chars
  refundEligible       Boolean     @default(true)

  createdAt           DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([buyerId])
  @@index([productId])
  @@index([status])
  @@map("orders")

  qrCode          QRCode?
}

model TrustTokenLedger {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("trust_token_ledger")
}

model SellerBadge {
  id         String    @id @default(uuid())
  supplierId String
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  tier       BadgeTier
  awardedAt  DateTime  @default(now())

  @@unique([supplierId, tier])
  @@map("seller_badges")
}

model WhatsAppSession {
  id            String        @id @default(uuid())
  phoneNumber   String        @unique
  supplierId    String?
  state         WhatsAppState @default(IDLE)
  sessionData   Json?
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([phoneNumber])
  @@map("whatsapp_sessions")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  referenceId String?
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model BuyerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  fullName       String?
  phoneNumber    String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  country        String?  @default("India")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("buyer_profiles")
}

// ─── Living QR Enums ──────────────────────────────────────────────────────────

enum QRPurpose {
  ORDER_BUYER
  ORDER_SUPPLIER
  PRODUCT_PROOF
  DELIVERY_CERT
}

enum ScanSource {
  BROWSER
  MACHINE
  API
}

// ─── Machine Scanner Registry ─────────────────────────────────────────────────

model MachineScanner {
  id              String    @id @default(uuid())
  apiKey          String    @unique
  apiKeyHint      String
  name            String
  deviceModel     String?
  firmwareVersion String?
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  fixedLat        Float?
  fixedLng        Float?
  fixedLocation   String?
  fixedCountry    String?

  isActive        Boolean   @default(true)
  totalScans      Int       @default(0)
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  scans           QRScan[]

  @@index([supplierId])
  @@map("machine_scanners")
}

// ─── QR Code Master Record ────────────────────────────────────────────────────

model QRCode {
  id               String     @id @default(uuid())

  orderId          String?    @unique
  order            Order?     @relation(fields: [orderId], references: [id])
  productId        String?
  product          Product?   @relation(fields: [productId], references: [id])
  supplierId       String?

  token            String     @unique
  shortCode        String     @unique
  purpose          QRPurpose

  totalScans       Int        @default(0)
  browserScans     Int        @default(0)
  machineScans     Int        @default(0)
  uniqueDevices    Int        @default(0)
  countriesReached String[]
  firstScannedAt   DateTime?
  lastScannedAt    DateTime?
  lastScannedCity  String?
  lastScannedCountry String?

  genesisAnchorTx  String?
  latestAnchorTx   String?
  totalAnchors     Int        @default(0)

  // GS1 Digital Link
  productGTIN    String?
  serialNumber   String?
  gs1DigitalLink String?

  // Expiry
  expiresAt      DateTime?
  isExpired      Boolean   @default(false)

  // Anomaly tracking
  anomalyCount   Int       @default(0)
  lastAnomalyAt  DateTime?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  scans            QRScan[]

  @@index([orderId])
  @@index([productId])
  @@map("qr_codes")
}

// ─── Individual Scan Event ────────────────────────────────────────────────────

model QRScan {
  id               String         @id @default(uuid())
  qrCodeId         String
  qrCode           QRCode         @relation(fields: [qrCodeId], references: [id])

  scanSource       ScanSource
  machineScannerIdRef String?
  machineScanner   MachineScanner? @relation(fields: [machineScannerIdRef], references: [id])

  scanNumber       Int

  clientTimestamp  DateTime?
  serverTimestamp  DateTime       @default(now())

  userAgent        String?        @db.Text
  deviceType       String?
  os               String?
  browser          String?
  screenResolution String?
  language         String?
  timezone         String?
  connectionType   String?
  referrer         String?        @db.Text
  isOnline         Boolean?

  gpsLat           Float?
  gpsLng           Float?
  gpsAccuracy      Float?
  gpsAltitude      Float?
  locationPermission String?

  machineDeviceId  String?
  machineModel     String?
  machineFirmware  String?
  rawScanData      String?        @db.Text
  machineEventType String?

  ipAddress        String?
  ipCountry        String?
  ipCountryName    String?
  ipCity           String?
  ipRegion         String?
  ipIsp            String?
  ipIsProxy        Boolean?       @default(false)
  ipLat            Float?
  ipLng            Float?

  resolvedLat      Float?
  resolvedLng      Float?
  resolvedLocation String?
  coordinateSource String?

  scannerRole      String?
  walletConnected  Boolean        @default(false)
  walletAddress    String?

  anchoredOnChain  Boolean        @default(false)
  anchorTxId       String?
  anchorReason     String?

  // Anomaly detection
  anomalyScore   Int       @default(0)
  anomalyReasons String[]

  // Ephemeral scan token (anti-replay)
  scanToken      String?   @unique
  scanTokenUsed  Boolean   @default(false)

  // View routing
  viewType       String?

  createdAt        DateTime       @default(now())

  @@index([qrCodeId])
  @@index([serverTimestamp])
  @@index([ipCountry])
  @@index([scanSource])
  @@map("qr_scans")
}

model Bounty {
  id              String       @id @default(uuid())
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  issuerId        String?
  issuer          User?        @relation("IssuerBounties", fields: [issuerId], references: [id])
  issuerWallet    String?
  amount          Decimal      @db.Decimal(18, 7)
  description     String
  status          BountyStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(STELLAR_USDC)
  transactionHash String?       @unique
  solverId        String?
  solver          User?        @relation("SolverBounties", fields: [solverId], references: [id])
  proofCid        String?
  proofUploadedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([productId])
  @@index([issuerId])
  @@index([solverId])
  @@map("bounties")
}

model Discussion {
  id           String   @id @default(uuid())
  title        String
  content      String   @db.Text
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id])
  authorWallet String?
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comments  Comment[]

  @@index([authorId])
  @@index([authorWallet])
  @@map("discussions")
}

model Comment {
  id           String     @id @default(uuid())
  content      String     @db.Text
  authorId     String?
  author       User?      @relation(fields: [authorId], references: [id])
  authorWallet String?
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([authorId])
  @@index([authorWallet])
  @@index([discussionId])
  @@map("comments")
}

generator seed {
  provider = "prisma-client-js"
}
